diff --git a/sys/unix/hints/include/cross-pre2.500 b/sys/unix/hints/include/cross-pre2.500
index ddc3ba7..26c02f7 100644
--- a/sys/unix/hints/include/cross-pre2.500
+++ b/sys/unix/hints/include/cross-pre2.500
@@ -282,7 +282,7 @@ EMCC_LFLAGS += -s MODULARIZE
 EMCC_LFLAGS += -s EXPORTED_FUNCTIONS='["_main", "_shim_graphics_set_callback", "_repopulate_perminvent", "_malloc"]'
 EMCC_LFLAGS += -s EXPORTED_RUNTIME_METHODS='["cwrap", "ccall", "addFunction", \
 			"removeFunction", "UTF8ToString", "stringToUTF8", "getValue", \
-			"setValue", "ENV", "FS", "IDBFS"]'
+			"setValue", "ENV", "FS", "IDBFS", "callMain"]'
 EMCC_LFLAGS += -s ERROR_ON_UNDEFINED_SYMBOLS=0
 EMCC_LFLAGS += -s EXPORT_ES6=1
 EMCC_LFLAGS += -lidbfs.js
@@ -295,7 +295,11 @@ EMCC_LFLAGS += --embed-file $(WASM_DATA_DIR)@/
 # WASM C flags
 EMCC_CFLAGS =
 EMCC_CFLAGS += -Wall
-EMCC_CFLAGS += -Werror
+# nethack-universal: upstream's -Werror is calibrated to the DevTeam's compiler.
+# emscripten 6.0.2 ships a newer clang that flags benign warnings (e.g.
+# -Wunused-but-set-variable on globals like cvtinit). Keep warnings visible but
+# don't fail the cross build on them.
+EMCC_CFLAGS += -Wno-error
 EMCC_CFLAGS += -DNO_SIGNAL
 #EMCC_CFLAGS += -s DISABLE_EXCEPTION_CATCHING=0
 EMCC_DEBUG_LFLAGS += -s ASSERTIONS=1
@@ -334,7 +338,24 @@ WASM_CFLAGS += -DSYSCF -DSYSCF_FILE=\"/sysconf\" -DSECURE
 WASM_CFLAGS += -I../include -DNOTPARMDECL
 # NetHack sources control
 WASM_CFLAGS += -DDLB
+# nethack-universal: redirect all read-write files (save/level/bones/lock/score)
+# to a single dir we mount as IDBFS in the browser for persistence; datadir
+# (nhdat) stays at HACKDIR. This needs CHDIR (config.h disables it whenever
+# SHIM_GRAPHICS is defined — chdirx()/fqn_prefix are simply never exercised
+# otherwise); PREFIXES_IN_USE (fqname() is an unconditional no-op without it, on
+# every platform, not just wasm) is then auto-defined by include/hack.h because
+# VAR_PLAYGROUND is set. dir == HACKDIR == "/" so the chdir("/") chdirx makes is
+# a no-op; only the fqn_prefix side effect matters to us.
+WASM_CFLAGS += -DCHDIR
+WASM_CFLAGS += -DVAR_PLAYGROUND=\"/nethack-data\"
 WASM_CFLAGS += -DHACKDIR=\"$(HACKDIR)\"
+# nethack-universal: HACKDIR above resolves to the HOST build machine's path
+# (from the Makefile $(HACKDIR) variable) — meaningless at WASM runtime, and
+# fatal here: chdirx() compares it against our runtime NETHACKDIR="/" env var
+# via strcmp to decide whether to apply VAR_PLAYGROUND, so a mismatched value
+# silently skips persistence setup entirely. Override to match; a later -D for
+# the same macro wins over the earlier one on the same compiler invocation.
+WASM_CFLAGS += -DHACKDIR=\"/\"
 WASM_CFLAGS += -DDEFAULT_WINDOW_SYS=\"shim\" \
 #override TARGET_CFLAGS += -DGREPPATH=\"/usr/bin/grep\"
 WASM_CFLAGS += -DNOMAIL
